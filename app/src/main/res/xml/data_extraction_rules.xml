<?xml version="1.0" encoding="utf-8"?>
<!-- Clipboard image history is sensitive user content — never back it up. -->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="file" path="clips/" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="file" path="clips/" />
    </device-transfer>
</data-extraction-rules>
